  "core_thesis": {
    "statement": "A European fragrance film is about the woman who wears it, observed in a mansion where power, clinic, and couture collapse into one ritual.",
    "portfolio_intention": "Chanel late-era grammar: Helleu simplicity, Lagerfeld codes, Newton power — no trademark."
  },
  "synthesis": {
    "three_pillars": {
      "newton": { "name": "The Voyeur's Mansion", "intention": "Power through observation; curved bodies with mass and threat" },
      "lagerfeld": { "name": "The Material Architect", "intention": "Self as garment — tweed, pearl, glove, irony" },
      "helleu": { "name": "The Abstract Woman", "intention": "Scent before name; unlabeled bottle; mythic absence" }
    },
    "unifying_meaning": "A curved powerful woman applies unnamed scent in a watching mansion. Dogs, steel, pearls witness. She leaves; scent remains; name never appears.",
    "interviewer_should_feel": "Candidate knows Chanel image = Helleu + Karl + Newton, executed with Pfrunder continuity."
  },
